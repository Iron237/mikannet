# 复制为 .env 后填写。三种典型部署见 DEPLOY.md。

# ============ NAS / 下载目录(CIFS 网络卷;Windows Docker Desktop 与「Linux+远程NAS」用)============
# mikannet 下载根所在的 SMB 共享,如 //192.168.1.100/anime/mikannet
NAS_SMB_PATH=//192.168.1.100/downloads
NAS_USER=nas用户名
NAS_PASS=nas密码

# ============ 本地绑定挂载(仅当用 deploy.sh local / docker-compose.local.yml,在 NAS 本机或本地盘跑)============
# 这台机器上的真实目录(绝对路径)。用 CIFS 方式部署时这几项忽略。
LOCAL_DOWNLOADS_PATH=/volume1/anime/mikannet
LOCAL_NAS_IMPORT_PATH=/volume1/anime
LOCAL_BD_OWNED_PATH=/volume1/anime/BD

# ============ 代理(本机所有外部服务都需要;容器内访问宿主代理用 host.docker.internal)============
PROXY_URL=http://host.docker.internal:10808

# TMDB API key(可选,横版背景图;留空则跳过)
TMDB_API_KEY=

# ============ 下载器 ============
# 后端:qb | bitcomet
DOWNLOADER=qb
QB_USER=admin
QB_PASS=adminadmin
# qB 连接目标:
#   容器版 qB → QB_HOST=qbittorrent  QB_PORT=18080  DOWNLOAD_ROOT=/downloads
#   桌面 qB(Win 下推荐,绕开 Docker 双重 NAT)→ host.docker.internal + 桌面端口 + NAS 的 Windows/UNC 路径
QB_HOST=qbittorrent
QB_PORT=18080
# 下载器写盘根目录(容器 qB 用 /downloads;桌面 qB 用 NAS 的 Windows 路径如 \\192.168.1.100\anime\mikannet)
DOWNLOAD_ROOT=/downloads

# RSS 轮询间隔(分钟)
POLL_INTERVAL_MIN=15

# ============ 本地番剧导入源(可选)============
# 1) Windows 本机磁盘 → 容器内 /import(填盘符路径如 G:/Anime,或保持 ./import)
LOCAL_IMPORT_PATH=./import
# 2) NAS 上的旧番剧目录(UNC)→ 容器内 /import-nas(CIFS,复用 NAS 账号)
NAS_IMPORT_PATH=//192.168.1.100/anime
# 3) 已购原盘目录(BD 收藏)→ 容器内 /bd-owned(CIFS);没有就忽略 / 删 compose 里 bd_owned 卷
BD_OWNED_PATH=//192.168.1.100/anime/BD
