# 复制为 .env 后填写

# NAS SMB 共享(下载目录),如 //192.168.1.100/anime
NAS_SMB_PATH=//192.168.1.100/downloads
NAS_USER=nas用户名
NAS_PASS=nas密码

# 代理(本机所有外部服务都需要;容器内访问宿主代理用 host.docker.internal)
PROXY_URL=http://host.docker.internal:10808

# TMDB API key(可选,横版背景图;留空则跳过)
TMDB_API_KEY=

# 下载器后端:qb | bitcomet
DOWNLOADER=qb

# qBittorrent WebUI 凭据
QB_USER=admin
QB_PASS=adminadmin
# qB 连接目标:
#   容器版 qB → QB_HOST=qbittorrent  QB_PORT=18080  DOWNLOAD_ROOT=/downloads
#   桌面 qB(绕开 Docker Desktop 双重 NAT,Win 下推荐)→ host.docker.internal + 桌面端口 + NAS 的 UNC 路径
QB_HOST=qbittorrent
QB_PORT=18080
# 下载器写盘根目录(容器 qB 用 /downloads;桌面 qB 用 NAS 的 Windows 路径如 \\192.168.1.100\anime\mikanarr)
DOWNLOAD_ROOT=/downloads
# 容器版 qB 的 BT 监听/发布端口(接桌面 qB 时无用)
QB_BT_PORT=51413

# RSS 轮询间隔(分钟)
POLL_INTERVAL_MIN=15

# 本地番剧导入源(两种来源都支持):
# 1) Windows 本机磁盘 → 容器内 /import(填盘符路径如 G:/Anime,或保持 ./import)
LOCAL_IMPORT_PATH=./import
# 2) NAS 上的旧番剧目录(UNC)→ 容器内 /import-nas(CIFS 挂载,复用 NAS 账号)
NAS_IMPORT_PATH=//192.168.1.100/anime
# 3) 已购原盘目录(BD 收藏)→ 容器内 /bd-owned(CIFS);没有就删 compose 里的 bd_owned 卷与挂载
BD_OWNED_PATH=//192.168.1.100/anime/BD
